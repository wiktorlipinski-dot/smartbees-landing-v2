{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/general/Benefits/**",
              "components/general/CtaBanner/**",
              "components/general/Faq/**",
              "components/general/Feature/**",
              "components/general/FinalCta/**",
              "components/general/FooterLp/**",
              "components/general/Hero/**",
              "components/general/Pricing/**",
              "components/general/Process/**",
              "components/general/Stats/**",
              "components/general/Testimonials/**",
              "components/general/TrustBar/**",
              "tweaks-panel.jsx"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Funnel Display|Inter))/i]",
        "message": "Font not provided by the design system. Available: Funnel Display, Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='Benefits'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|tone|title|subtitle|items|key|ref|className|style|children)$/]",
        "message": "<Benefits> doesn't accept that prop. Declared props: variant, tone, title, subtitle, items."
      },
      {
        "selector": "JSXOpeningElement[name.name='Benefits'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:a|b)$/]",
        "message": "<Benefits> variant must be one of 'a' | 'b'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Benefits'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:base|dim|panel|ember)$/]",
        "message": "<Benefits> tone must be one of 'base' | 'dim' | 'panel' | 'ember'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CtaBanner'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|tone|title|sub|ctaLabel|key|ref|className|style|children)$/]",
        "message": "<CtaBanner> doesn't accept that prop. Declared props: variant, tone, title, sub, ctaLabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='CtaBanner'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:a|b)$/]",
        "message": "<CtaBanner> variant must be one of 'a' | 'b'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CtaBanner'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:base|dim|panel|ember)$/]",
        "message": "<CtaBanner> tone must be one of 'base' | 'dim' | 'panel' | 'ember'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Faq'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|title|items|defaultOpen|key|ref|className|style|children)$/]",
        "message": "<Faq> doesn't accept that prop. Declared props: tone, title, items, defaultOpen."
      },
      {
        "selector": "JSXOpeningElement[name.name='Faq'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:base|dim|panel|ember)$/]",
        "message": "<Faq> tone must be one of 'base' | 'dim' | 'panel' | 'ember'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Feature'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|title|ctaLabel|bullets|hideMockup|key|ref|className|style|children)$/]",
        "message": "<Feature> doesn't accept that prop. Declared props: tone, title, ctaLabel, bullets, hideMockup."
      },
      {
        "selector": "JSXOpeningElement[name.name='Feature'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:base|dim|panel|ember)$/]",
        "message": "<Feature> tone must be one of 'base' | 'dim' | 'panel' | 'ember'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FinalCta'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|tone|title|sub|ctaLabel|benefits|key|ref|className|style|children)$/]",
        "message": "<FinalCta> doesn't accept that prop. Declared props: variant, tone, title, sub, ctaLabel, benefits."
      },

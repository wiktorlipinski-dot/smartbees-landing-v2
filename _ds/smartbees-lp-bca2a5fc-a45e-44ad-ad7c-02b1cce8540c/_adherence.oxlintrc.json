        "message": "<FooterLp> doesn't accept that prop. Declared props: tone, trustChips."
      },
      {
        "selector": "JSXOpeningElement[name.name='FooterLp'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:base|dim|panel|ember)$/]",
        "message": "<FooterLp> tone must be one of 'base' | 'dim' | 'panel' | 'ember'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Hero'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|tone|title|formTitle|ctaLabel|pills|trustLogos|hideTopbar|key|ref|className|style|children)$/]",
        "message": "<Hero> doesn't accept that prop. Declared props: variant, tone, title, formTitle, ctaLabel, pills, trustLogos, hideTopbar."
      },
      {
        "selector": "JSXOpeningElement[name.name='Hero'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:a|b)$/]",
        "message": "<Hero> variant must be one of 'a' | 'b'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Hero'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:base|dim|panel|ember)$/]",
        "message": "<Hero> tone must be one of 'base' | 'dim' | 'panel' | 'ember'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pricing'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|title|plans|key|ref|className|style|children)$/]",
        "message": "<Pricing> doesn't accept that prop. Declared props: tone, title, plans."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pricing'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:base|dim|panel|ember)$/]",
        "message": "<Pricing> tone must be one of 'base' | 'dim' | 'panel' | 'ember'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Process'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|title|steps|key|ref|className|style|children)$/]",
        "message": "<Process> doesn't accept that prop. Declared props: tone, title, steps."
      },
      {
        "selector": "JSXOpeningElement[name.name='Process'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:base|dim|panel|ember)$/]",
        "message": "<Process> tone must be one of 'base' | 'dim' | 'panel' | 'ember'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stats'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|title|items|key|ref|className|style|children)$/]",
        "message": "<Stats> doesn't accept that prop. Declared props: tone, title, items."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stats'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:base|dim|panel|ember)$/]",
        "message": "<Stats> tone must be one of 'base' | 'dim' | 'panel' | 'ember'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Testimonials'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|tone|title|quotes|key|ref|className|style|children)$/]",
        "message": "<Testimonials> doesn't accept that prop. Declared props: variant, tone, title, quotes."
      },
      {
        "selector": "JSXOpeningElement[name.name='Testimonials'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:a|b)$/]",
        "message": "<Testimonials> variant must be one of 'a' | 'b'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Testimonials'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:base|dim|panel|ember)$/]",
        "message": "<Testimonials> tone must be one of 'base' | 'dim' | 'panel' | 'ember'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrustBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|heading|logos|key|ref|className|style|children)$/]",
        "message": "<TrustBar> doesn't accept that prop. Declared props: tone, heading, logos."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrustBar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:base|dim|panel|ember)$/]",
        "message": "<TrustBar> tone must be one of 'base' | 'dim' | 'panel' | 'ember'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "Benefits": {
        "replaces": []
